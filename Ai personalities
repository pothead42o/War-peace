import random

class PersonalityProfile:
    def __init__(self, traits):
        self.traits = traits

    def get_trait(self, key):
        return self.traits.get(key, 0.5)


class NHPBrain:
    def __init__(self, profile: PersonalityProfile):
        self.profile = profile
        self.state = {
            "war_status": False,
            "economy_strength": 0.5,
            "territory_size": 0.5,
            "neighbor_threat": 0.5
        }

    def analyze_situation(self, world_data):
        """Update situation awareness"""
        self.state.update(world_data)

    def choose_strategy(self):
        a = self.profile.get_trait("aggression")
        e = self.profile.get_trait("expansionism")
        t = self.profile.get_trait("tech_focus")
        d = self.profile.get_trait("diplomacy_trust")
        r = self.profile.get_trait("risk_tolerance")

        # Heuristic weighting
        if self.state["war_status"]:
            if a > 0.7:
                strategy = "Full Assault"
            elif d > 0.6:
                strategy = "Peace Negotiation"
            else:
                strategy = "Defensive Retaliation"
        elif e > 0.7 and self.state["economy_strength"] > 0.5:
            strategy = "Expansion"
        elif t > 0.7:
            strategy = "Research Focus"
        elif r > 0.8:
            strategy = random.choice(["Risky Expansion", "Unconventional Strike"])
        else:
            strategy = "Balanced Development"

        return {
            "current_strategy": strategy,
            "justification": f"Based on traits (A:{a}, E:{e}, T:{t}, D:{d}, R:{r}) and situation {self.state}."
        }


